+static std::string b64_encode(const std::string&in){
+    std::string out;uint32_t val=0;int valb=-6;for(unsigned char c:in){val=(val<<8)+c;valb+=8;while(valb>=0){out.push_back(B64[(val>>valb)&0x3f]);valb-=6;}}
