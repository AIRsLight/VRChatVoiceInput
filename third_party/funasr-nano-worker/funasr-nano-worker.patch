+static bool b64_decode(const std::string&in,std::string&out){
+    static std::vector<int>table=[](){std::vector<int>t(256,-1);for(int i=0;i<64;i++)t[(unsigned char)B64[i]]=i;return t;}();
+    out.clear();uint32_t val=0;int valb=-8;for(unsigned char c:in){if(c=='=')break;if(table[c]<0)return false;val=(val<<6)+table[c];valb+=6;if(valb>=0){out.push_back(char((val>>valb)&0xff));valb-=8;}}return true;
+}
