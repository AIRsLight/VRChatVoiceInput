<Window x:Class="VRChatVoiceInput.App.NativeMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:VRChatVoiceInput.App"
        Title="VRChat Voice Input"
        Width="1180"
        Height="780"
        MinWidth="900"
        MinHeight="640"
        Icon="Assets/app-icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F2"
        FontFamily="Segoe UI Variable, Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#087E72" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#066C62" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E3F1EE" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedSurfaceBrush" Color="#F7F8F6" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D9DED9" />
        <SolidColorBrush x:Key="TextBrush" Color="#202622" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#66706A" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#C3CBC5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F3F6F4" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#9FA9A2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PrimaryBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PrimaryBorder" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="PrimaryBorder" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="IconButtonStyle" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style TargetType="Button" x:Key="ProfileItemButtonStyle">
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ProfileBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ProfileBorder" Property="Background" Value="White" />
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="ProfileBorder" Property="Background" Value="#E8F3F0" />
                                <Setter TargetName="ProfileBorder" Property="BorderBrush" Value="#B5D8D0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="TabButtonStyle">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="Margin" Value="0,0,18,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border x:Name="TabIndicator" Height="2" Background="Transparent"
                                    VerticalAlignment="Bottom" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#075F57" />
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="TabIndicator" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SegmentButtonStyle">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="BorderBrush" Value="#C3CBC5" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SegmentBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="#F3F6F4" />
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="#075F57" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="ModelTabButtonStyle">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="11,0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ModelTabBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ModelTabBorder" Property="Background" Value="#F3F6F4" />
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="ModelTabBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="#075F57" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="NavButtonStyle">
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="11,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#DCE3DF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2B3530" />
                            </Trigger>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="Border" Property="Background" Value="#DCEFE9" />
                                <Setter Property="Foreground" Value="#114A43" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#C3CBC5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="SelectionBrush" Value="#8ACBC1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource MutedSurfaceBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource MutedSurfaceBrush}" />
                                <Setter Property="Foreground" Value="#9CA49E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="#075F57" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#D8EEE9" />
                                <Setter Property="Foreground" Value="#075F57" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="10,0,34,0" />
            <Setter Property="BorderBrush" Value="#C3CBC5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MaxDropDownHeight" Value="320" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5" />
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                            <Path Data="{x:Static local:MaterialIconPaths.ChevronDown}"
                                  Width="13"
                                  Height="13"
                                  Stretch="Uniform"
                                  Fill="{StaticResource MutedTextBrush}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  IsHitTestVisible="False"
                                  Margin="0,0,11,0" />
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, ElementName=DropDownToggle}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,3,0,0"
                                        Padding="1"
                                        Background="White"
                                        BorderBrush="#B8C1BA"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.16" />
                                    </Border.Effect>
                                    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#9FA9A2" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Background" Value="{StaticResource MutedSurfaceBrush}" />
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent" MinHeight="36">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              Margin="0,0,18,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                            <Border x:Name="SwitchTrack"
                                    Grid.Column="1"
                                    Width="34"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="#B9C0BB"
                                    VerticalAlignment="Center">
                                <Ellipse x:Name="SwitchThumb"
                                         Width="14"
                                         Height="14"
                                         Margin="3"
                                         Fill="White"
                                         HorizontalAlignment="Left">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.25" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Border" x:Key="SectionStyle">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,0,0,20" />
            <Setter Property="Margin" Value="0,0,0,20" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="216" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#202824" Padding="12,18,12,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="#35403A" BorderThickness="0,0,0,1" Padding="10,0,10,16">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="30" Height="30" CornerRadius="6" Background="#D8EEE9">
                            <Path Data="{x:Static local:MaterialIconPaths.Waveform}" Width="16" Height="16"
                                  Stretch="Uniform" Fill="#075F57"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="BrandTitle" Text="Voice Input" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock x:Name="BrandSubtitle" Text="VRChat companion" Foreground="#AEB9B2" FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Row="1" Margin="0,16,0,0">
                    <Button x:Name="GeneralNav" Style="{StaticResource NavButtonStyle}" Click="OnNavigate" CommandParameter="general">
                        <StackPanel Orientation="Horizontal"><Grid Width="28"><Path Data="{x:Static local:MaterialIconPaths.CogOutline}" Width="16" Height="16" Stretch="Uniform" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" HorizontalAlignment="Left" /></Grid><TextBlock x:Name="GeneralNavText" Text="General" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" /></StackPanel>
                    </Button>
                    <Button x:Name="ProfilesNav" Style="{StaticResource NavButtonStyle}" Click="OnNavigate" CommandParameter="profiles">
                        <StackPanel Orientation="Horizontal"><Grid Width="28"><Path Data="{x:Static local:MaterialIconPaths.AccountOutline}" Width="16" Height="16" Stretch="Uniform" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" HorizontalAlignment="Left" /></Grid><TextBlock x:Name="ProfilesNavText" Text="Profiles" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" /></StackPanel>
                    </Button>
                    <Button x:Name="ModelsNav" Style="{StaticResource NavButtonStyle}" Click="OnNavigate" CommandParameter="models">
                        <StackPanel Orientation="Horizontal"><Grid Width="28"><Path Data="{x:Static local:MaterialIconPaths.Memory}" Width="16" Height="16" Stretch="Uniform" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" HorizontalAlignment="Left" /></Grid><TextBlock x:Name="ModelsNavText" Text="Models" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" /></StackPanel>
                    </Button>
                    <Button x:Name="DiagnosticsNav" Style="{StaticResource NavButtonStyle}" Click="OnNavigate" CommandParameter="diagnostics">
                        <StackPanel Orientation="Horizontal"><Grid Width="28"><Path Data="{x:Static local:MaterialIconPaths.ChartBoxOutline}" Width="16" Height="16" Stretch="Uniform" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" HorizontalAlignment="Left" /></Grid><TextBlock x:Name="DiagnosticsNavText" Text="Diagnostics" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" /></StackPanel>
                    </Button>
                </StackPanel>
                <Border Grid.Row="3" BorderBrush="#35403A" BorderThickness="0,1,0,0" Padding="10,12,10,0">
                    <StackPanel>
                        <TextBlock x:Name="VersionText" Foreground="#AEB9B2" FontSize="11" />
                        <TextBlock Text="Native WPF" Foreground="#AEB9B2" FontSize="11" Margin="0,3,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitle" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="PageContext" Foreground="{StaticResource MutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <Ellipse x:Name="RuntimeDot" Width="8" Height="8" Fill="#9DA59F" Margin="0,0,7,0" />
                        <TextBlock x:Name="RuntimeStatusText" Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="SaveStatusText" Grid.Column="2" Foreground="{StaticResource MutedTextBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="8,0,12,0" />
                    <Button x:Name="RuntimeToggleButton" Grid.Column="3" Width="34" Height="34" Padding="0"
                            Style="{StaticResource ActionButtonStyle}" Click="OnRuntimeToggle">
                        <Path x:Name="RuntimeToggleIcon" Width="16" Height="16" Stretch="Uniform"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                    </Button>
                </Grid>
            </Border>

            <Border x:Name="DownloadPanel" Grid.Row="1" Background="#E3F1EE" BorderBrush="#B9D9D1"
                    BorderThickness="0,0,0,1" Padding="24,10" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="DownloadText" FontSize="11" Foreground="#245C53" />
                        <ProgressBar x:Name="DownloadProgress" Height="4" Margin="0,7,14,0" Minimum="0" Maximum="100" Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" Width="32" Height="32" Padding="0" Style="{StaticResource ActionButtonStyle}" Click="OnCancelDownload" ToolTip="Cancel download">
                        <Path Data="{x:Static local:MaterialIconPaths.Close}" Width="16" Height="16" Stretch="Uniform"
                              Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                    </Button>
                </Grid>
            </Border>

            <ContentControl x:Name="PageContent" Grid.Row="2" />
        </Grid>

        <Border x:Name="Toast" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,24,22" Padding="14,10" Background="#202824" CornerRadius="5"
                Visibility="Collapsed" MaxWidth="520">
            <TextBlock x:Name="ToastText" Foreground="White" TextWrapping="Wrap" FontSize="12" />
        </Border>
    </Grid>
</Window>
