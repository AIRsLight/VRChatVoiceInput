<Window x:Class="VRChatVoiceInput.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="VRChat Voice Input"
        Width="1180"
        Height="780"
        MinWidth="900"
        MinHeight="640"
        Icon="Assets/app-icon.ico"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F2">
    <Grid>
        <wv2:WebView2 x:Name="WebView" Visibility="Hidden" />
        <Border x:Name="LoadingPanel" Background="#F3F4F2">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar x:Name="LoadingProgress" Width="220" Height="3" IsIndeterminate="True" Foreground="#087E72" />
                <TextBlock x:Name="LoadingText" Margin="0,18,0,0"
                           MaxWidth="560"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           Foreground="#4B514D"
                           Text="Loading configuration..." />
                <TextBlock x:Name="ErrorLogPath" Margin="0,10,0,0"
                           MaxWidth="560"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           FontFamily="Cascadia Mono, Consolas"
                           FontSize="11"
                           Foreground="#737A75"
                           Visibility="Collapsed" />
                <StackPanel x:Name="LoadingActions" Margin="0,18,0,0"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Visibility="Collapsed">
                    <Button x:Name="RetryInterfaceButton" MinWidth="110" Height="32" Margin="0,0,8,0"
                            Click="OnRetryInterfaceClick" Content="Retry interface" />
                    <Button x:Name="OpenLogsButton" MinWidth="110" Height="32"
                            Click="OnOpenLogsClick" Content="Open logs" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
